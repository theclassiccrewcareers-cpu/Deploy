{
    "version": 2,
    "builds": [
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        }
    ],
    "outputDirectory": ".",
    "rewrites": [
        {
            "source": "/(.*\\.(js|css|png|jpg|jpeg|svg|json|ico))",
            "destination": "/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}